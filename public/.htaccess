<IfModule mod_mime.c>
  AddType text/css .css
  AddType application/javascript .js
</IfModule>

# Force correct MIME types for assets (some hosts ignore AddType for /assets/)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve /assets/*.css and /assets/*.js as static files with correct type (do not rewrite)
  RewriteRule ^assets/.*\.css$ - [L,T=text/css]
  RewriteRule ^assets/.*\.js$ - [L,T=application/javascript]

  # Any other path under /assets/
  RewriteRule ^assets/ - [L]

  # Never rewrite real files or directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback: all other paths -> index.html
  RewriteRule . /index.html [L]
</IfModule>

